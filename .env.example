APP_NAME="CHAZ - Churches Health Association of Zambia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=chaz
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

# Lenco by Broadpay Payment Gateway
# API docs: https://lenco-api.readme.io/v2.0/reference/introduction
LENCO_API_URL=https://api.lenco.co/access/v2
LENCO_API_KEY=
LENCO_CURRENCY=ZMW
LENCO_COUNTRY=zm

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@chaz.org.zm"
MAIL_FROM_NAME="${APP_NAME}"
